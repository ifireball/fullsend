#!/usr/bin/env bash
set -euo pipefail

OUTPUT_DIR="${FULLSEND_OUTPUT_DIR:-output}"
mkdir -p "$OUTPUT_DIR"

cat > "$OUTPUT_DIR/hello-world.md" <<EOF
# Hello World

Hello world from repo $(basename "$(git remote get-url origin)" .git).

Generated at $(date -u +"%Y-%m-%dT%H:%M:%SZ").
EOF

echo "Wrote $OUTPUT_DIR/hello-world.md"
